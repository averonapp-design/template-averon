{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "ios": {
        "distribution": "store",
        "resourceClass": "m-medium"
      },
      "android": {
        "distribution": "internal",
        "buildType": "apk"
      },
      "env": {
        "RCT_USE_PREBUILT_RNCORE": "0",
        "RCT_USE_RN_DEP": "0",
        "EXPO_PUBLIC_PROXY_BASE": "https://www.averonapp.com"
      }
    },
    "app-store": {
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "RCT_USE_PREBUILT_RNCORE": "0",
        "RCT_USE_RN_DEP": "0",
        "EXPO_PUBLIC_PROXY_BASE": "https://flamengo-app.replit.app/api"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "RCT_USE_PREBUILT_RNCORE": "0",
        "RCT_USE_RN_DEP": "0",
        "EXPO_PUBLIC_PROXY_BASE": "https://www.averonapp.com"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
