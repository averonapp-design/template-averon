{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "RCT_USE_PREBUILT_RNCORE": "0",
        "RCT_USE_RN_DEP": "0",
        "EXPO_PUBLIC_PROXY_BASE": "https://flamengo-app.replit.app/api"
      }
    },
    "app-store": {
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "RCT_USE_PREBUILT_RNCORE": "0",
        "RCT_USE_RN_DEP": "0",
        "EXPO_PUBLIC_API_KEY": "avr_d43ada04d4a714f5d71572c51a432804b845ff44c336af1dd2650d3a",
        "EXPO_PUBLIC_PROXY_BASE": "https://flamengo-app.replit.app/api"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "RCT_USE_PREBUILT_RNCORE": "0",
        "RCT_USE_RN_DEP": "0",
        "EXPO_PUBLIC_API_KEY": "avr_d43ada04d4a714f5d71572c51a432804b845ff44c336af1dd2650d3a",
        "EXPO_PUBLIC_PROXY_BASE": "https://flamengo-app.replit.app/api"
      }
